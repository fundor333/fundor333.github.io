@charset "UTF-8";@import "https://fonts.googleapis.com/css2?family=Audiowide&family=Rajdhani:wght@300;400;500;600;700&display=swap";@font-face{font-family:ocean trace;src:url(/fonts/OceanTrace-Personal.ttf)format("truetype");font-display:swap}:root,[data-bs-theme=light]{--bs-body-font-family:"Rajdhani", sans-serif;--bs-body-font-size:1.1rem;--bs-body-line-height:1.85;--bs-font-monospace:Consolas, monospace;--bs-link-color:#003fff;--bs-link-hover-color:#0036c7;--bs-code-color:#333638;--blockquote-border-color:#c4c8cc;--blockquote-bg:rgb(248 248 248);--pre-bg:#272822;--pre-color:#f8f8f2;--inline-code-bg:rgba(0, 0, 0, 0.12);--table-stripe-bg:#efefee;--accent-color:#003fff;--accent-color-text:#fff;--neutral:#6b7886}[data-bs-theme=dark]{--bs-link-color:#77a8fd;--bs-link-hover-color:#5292ff;--bs-code-color:rgba(255, 255, 255, 0.9);--blockquote-bg:rgb(75 75 75);--blockquote-border-color:#4a4d56;--inline-code-bg:#2d2d2d;--table-stripe-bg:#545454;--neutral:#9ca3af}h1,h2,h3,h4,h5,h6,.h1,.h2,.h3,.h4,.h5,.h6{font-family:audiowide,sans-serif}a{font-family:audiowide,sans-serif}strong{font-family:audiowide,sans-serif;font-weight:400}.written-by-human{font-family:ocean trace,cursive;font-style:italic;font-size:2.4em;margin-top:2em;opacity:.8;text-align:center}.typewriter{font-family:ocean trace,cursive}.footer-copyright{font-family:audiowide,sans-serif}blockquote{border-left:4px solid var(--blockquote-border-color);background-color:var(--blockquote-bg);padding:.75rem 1rem;border-radius:0 .375rem .375rem 0}pre{background-color:var(--pre-bg);color:var(--pre-color);border-radius:.375rem;padding:1rem;overflow-x:auto}code{background-color:var(--inline-code-bg);color:var(--bs-code-color);padding:.15em .4em;border-radius:.25rem;font-family:var(--bs-font-monospace)}pre code{background-color:initial;color:inherit;padding:0}table.table tr:nth-child(even) td{background-color:var(--table-stripe-bg)}.navbar-brand{font-family:audiowide,sans-serif;font-size:1.1rem}.nav-link{font-family:audiowide,sans-serif}.post-meta{color:var(--bs-secondary-color);font-size:.9rem;margin-bottom:1rem}.post-meta a{font-family:inherit}.tag-link{font-family:audiowide,sans-serif;font-size:.75rem}.e-content img{max-width:100%;height:auto;border-radius:.375rem}.e-content figure{text-align:center}.e-content figure img{display:block;margin:0 auto}.e-content figure figcaption{color:var(--bs-secondary-color);font-size:.875rem;margin-top:.5rem}.e-content a[target=_blank]::after{display:none}.weeknote .e-content img{max-width:100%}.nowrap{white-space:nowrap}.footnotes p{margin:0}.toot{background-color:var(--bs-body-bg);border:1px solid var(--bs-border-color);border-radius:.75rem;box-shadow:0 1px 3px rgba(0,0,0,.1);padding:1rem;margin:1.5rem auto;max-width:600px;font-family:-apple-system,BlinkMacSystemFont,system-ui,sans-serif}.toot-header{display:flex;align-items:flex-start;gap:.75rem;margin-bottom:.75rem}.toot-profile img{width:48px;height:48px;border-radius:4px}.toot-author{display:flex;flex-direction:column;gap:2px}.toot-author-name{color:var(--bs-emphasis-color);font-weight:700;text-decoration:none;font-size:.9375rem}.toot-author-handle{color:var(--bs-secondary-color);text-decoration:none;font-size:.875rem}.toot-content{color:var(--bs-body-color);font-size:.9375rem;line-height:1.5;margin:.75rem 0}.toot-content p{margin:0 0 .75rem}.toot-content p:last-child{margin-bottom:0}.toot-content a{color:#2b90d9;text-decoration:none}.toot-content a:hover{text-decoration:underline}.toot-media-grid{display:grid;gap:.5rem;margin:.75rem 0;border-radius:.75rem;overflow:hidden}.toot-media-grid[data-count="1"]{grid-template-columns:1fr}.toot-media-grid[data-count="2"]{grid-template-columns:repeat(2,1fr)}.toot-media-grid[data-count="3"]{grid-template-columns:repeat(2,1fr)}.toot-media-grid[data-count="3"]>:first-child{grid-column:1/-1}.toot-media-grid[data-count="4"]{grid-template-columns:repeat(2,1fr)}.toot-media-item img{width:100%;height:auto;border-radius:4px}.toot-footer{margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--bs-border-color);color:var(--bs-secondary-color);font-size:.875rem}.toot-date{color:inherit;text-decoration:none}.toot-date:hover{text-decoration:underline}section#comments #comments-wrapper{margin:1.5em 0}section#comments .comment{display:grid;column-gap:1rem;grid-template-areas:"avatar name" "avatar time" "avatar post" "...... interactions";grid-template-columns:min-content;justify-items:start;margin:0 auto 0 -1em;padding:.5em}section#comments .comment.comment-reply{margin-left:1em}section#comments .comment .avatar-link{grid-area:avatar;height:4rem;width:4rem;position:relative}section#comments .comment .avatar-link .avatar{height:100%;width:100%;border-radius:20%}section#comments .comment .avatar-link.op::after{background-color:var(--accent-color);border-radius:50%;bottom:-.25rem;color:var(--accent-color-text);content:"✓";display:block;font-size:1.25rem;font-weight:700;height:1.5rem;line-height:1.5rem;position:absolute;right:-.25rem;text-align:center;width:1.5rem}section#comments .comment .author{align-items:center;display:flex;font-weight:700;gap:.5em;grid-area:name}section#comments .comment .author .instance{background-color:var(--inline-code-bg);border-radius:9999px;color:var(--neutral);font-size:smaller;font-weight:400;padding:.25em .75em}section#comments .comment .author .instance:hover{opacity:.8;text-decoration:none}section#comments .comment time{font-size:smaller;opacity:.9;grid-area:time;line-height:1.5rem}section#comments .comment main{grid-area:post}section#comments .comment main p:first-child{margin-top:.25em}section#comments .comment main p:last-child{margin-bottom:0}section#comments .comment footer{font-size:smaller;opacity:.9;grid-area:interactions}section#comments .comment footer .faves{color:inherit}section#comments .comment footer .faves:hover{opacity:.8;text-decoration:none}section#comments .comment footer .faves::before{color:red;content:"♥";font-size:2rem;margin-inline-end:.25em}section#comments .comment .emoji{display:inline;height:1.25em;vertical-align:middle;width:1.25em}section#comments .comment .invisible{display:none}section#comments .comment .ellipsis::after{content:"…"}#webmentions{position:relative;z-index:100;line-height:1.2em}#webmentions .comments{overflow-x:hidden;overflow-y:scroll}#webmentions h2{font-size:medium;margin:0;padding:2px}#webmentions .reacts img{margin:3px -1ex 8px 0}#webmentions img.missing{border:dashed var(--bs-border-color)1px}#webmentions ul{list-style-type:none;margin:0;padding:4px}#webmentions li{text-indent:-1em;padding-left:1em}#webmentions a.reaction{position:relative;text-decoration:none;letter-spacing:-1ex;margin-right:3ex}#webmentions a.reaction img{max-height:3em;width:auto;margin-right:-1ex;border-radius:25%}#webmentions a.reaction sub{font-size:50%}#webmentions .comments li{white-space:nowrap;text-overflow:ellipsis;overflow:hidden}#webmentions .comments li .text{font-style:italic;text-decoration:none}.badges-88x31{display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:8px;margin:0!important}.badges-88x31 img{display:block;width:88px;height:31px;margin:0!important}.badges-88x31-link{display:inline-block;width:88px;height:31px;margin:0!important}#totop{position:fixed;bottom:2rem;right:2rem;display:none;z-index:1050;width:3rem;height:3rem;border-radius:50%;background-color:var(--bs-body-bg);border:1px solid var(--bs-border-color);box-shadow:0 2px 6px rgba(0,0,0,.15);cursor:pointer;align-items:center;justify-content:center;text-decoration:none;color:var(--bs-body-color);transition:opacity .2s}#totop.visible{display:flex}#totop:hover{opacity:.8;color:var(--bs-body-color)}.e-content img.img-fluid{border-radius:.375rem}.heading-anchor{opacity:0;margin-left:.5rem;text-decoration:none;color:var(--bs-secondary-color);font-size:.8em;transition:opacity .2s;font-family:inherit}h1:hover .heading-anchor,h2:hover .heading-anchor,h3:hover .heading-anchor,h4:hover .heading-anchor,h5:hover .heading-anchor,h6:hover .heading-anchor{opacity:1}share-button{display:block;margin:1rem 0}.p-author.h-card,.p-summary,.u-url[style*="display: none"],a.u-url[style*="display: none"]{display:none!important}.post-year-heading{font-family:audiowide,sans-serif;border-bottom:2px solid var(--bs-border-color);padding-bottom:.5rem;margin-top:2rem}